<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- MYR-247 — Apple privacy manifest (required for App Store submission).
	     The app does no cross-app tracking and declares only the required-reason
	     APIs it actually calls. UserDefaults is the sole required-reason API in
	     use (App/Sources: AccountStorage, AuthSession, RootView) — it stores this
	     app's own session/account state and is never shared, so reason CA92.1
	     (access info from the same app) applies. No file-timestamp, system-boot,
	     disk-space, or active-keyboard APIs are used. -->
	<key>NSPrivacyTracking</key>
	<false/>
	<key>NSPrivacyTrackingDomains</key>
	<array/>
	<key>NSPrivacyCollectedDataTypes</key>
	<array/>
	<key>NSPrivacyAccessedAPITypes</key>
	<array>
		<dict>
			<key>NSPrivacyAccessedAPIType</key>
			<string>NSPrivacyAccessedAPICategoryUserDefaults</string>
			<key>NSPrivacyAccessedAPITypeReasons</key>
			<array>
				<string>CA92.1</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
